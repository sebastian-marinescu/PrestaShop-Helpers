# ------------------------------------------------------------------------------
# Staging Sync Script Configuration Template
# Copy this file to '.env' in the same folder and configure your local settings.
# ------------------------------------------------------------------------------

# Sync Mode: 'local' (if production is on the same server) or 'remote' (not implemented/needed for this setup)
SYNC_MODE=local

# Absolute directory paths of environments
# Note: The script will automatically resolve symlinks if any of these are symlinks.
PROD_DIR=/home/www/production
STAGING_DIR=/home/www/staging

# Domains/URLs (without protocol prefix, e.g. 'domain.ch')
PROD_DOMAIN=domain.com
STAGING_DOMAIN=staging.domain.com

# Staging-Only WIP Preservation
# If true, the script automatically compares staging/modules and production/modules.
# Any directories unique to Staging (e.g. 'usm_configurator') will be preserved.
AUTO_PRESERVE_STAGING_ONLY_MODULES=true

# Manual path preservation (space-separated relative paths to keep, e.g. "modules/some_custom_module")
PRESERVE_PATHS=""

# Image Sync
# If false, the script will skip syncing '/img/' physically (recommended, as the script
# will automatically configure Apache rules on Staging to fall back to Production images).
# Set to true if you want a complete physical rsync of the '/img/' folder.
SYNC_IMAGES=false

# Database Sync Optimization
# If true, skips importing heavy log and statistics table data (ps_log, ps_connections, ps_guest, etc.)
# while keeping their empty table structures. This speeds up DB sync by up to 90%.
EXCLUDE_HEAVY_DB_DATA=true

